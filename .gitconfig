[user]
  name = Marius Breivik
  email = marius.breivik@gmail.com
[color]
  ui = true
[core]
  editor = vim
  filemode = false
[push]
    default = simple
[format]
  pretty=format:%C(yellow)%h%Creset -%C(red)%d%Creset %s %Cgreen(%ar) %C(bold blue)<%an>%Creset
	rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
