[user]
  name = Marius Breivik
  email = marius.breivik@gmail.com

[init]
  defaultBranch = main

[core]
  editor = vim
  filemode = false
  excludesFile = ~/.gitignore

[color]
  ui = true

[push]
  default = current
  autoSetupRemote = true
  followTags = true

[pull]
  rebase = true

[fetch]
  prune = true
  prunetags = true

[rebase]
  autosquash = true
  autostash = true
  updateRefs = true

[merge]
  conflictstyle = zdiff3

[diff]
  algorithm = histogram
  colorMoved = default

[rerere]
  enabled = true

[branch]
  sort = -committerdate

[commit]
  verbose = true

[help]
  autocorrect = prompt

[transfer]
  fsckobjects = true

[format]
  pretty = format:%C(yellow)%h%Creset -%C(red)%d%Creset %s %Cgreen(%ar) %C(bold blue)<%an>%Creset

[alias]
  fpush = push --force-with-lease
  lg = log --oneline --graph --decorate -20
  undo = reset --soft HEAD~1
  amend = commit --amend --no-edit

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
